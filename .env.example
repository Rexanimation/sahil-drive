# ─── Sahil Drive — Server Configuration ───
PORT=3000
MONGO_URI=your_mongodb_connection_string
JWT_SECRET=your_jwt_secret_token

# ─── OAuth (Optional — mock fallback works in dev) ───
GOOGLE_CLIENT_ID=your_google_client_id
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
VITE_GOOGLE_CLIENT_ID=your_google_client_id
VITE_GITHUB_CLIENT_ID=your_github_client_id
GROQ_API_KEY=your_groq_api_key

# ─── Optional Pinecone & Hugging Face Memory ───
HF_API_KEY=your_huggingface_api_key
PINECONE_API_KEY=your_pinecone_api_key
PINECONE_INDEX=cohort-chat-gpt

# ─── Optional AWS S3 Storage (Alternative to local storage) ───
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=your_aws_region
AWS_BUCKET_NAME=your_sahil_drive_bucket
